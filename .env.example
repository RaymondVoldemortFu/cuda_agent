# 开发环境：复制为 .env 后填写（勿提交含真实密钥的 .env）
# 生产评测仅使用进程环境变量，不读取本文件。

API_KEY=
BASE_URL=
BASE_MODEL=gpt-4o

# development | production（development 时可选加载根目录 .env）
HW_PROBE_ENVIRONMENT=development

# 显式为 1 时，在 development 下也会尝试 load_dotenv（默认 development 已会加载）
# HW_PROBE_LOAD_DOTENV=1

# 本地：HW_PROBE_ENVIRONMENT=development 时，若未显式设置下列变量，会自动使用相对路径：
#   workspace = .     target_spec = target/target_spec.json
# 评测容器请使用 production（默认）或显式设置：
#   HW_PROBE_WORKSPACE_ROOT=/workspace
#   HW_PROBE_TARGET_SPEC_PATH=/target/target_spec.json

# HW_PROBE_WORKSPACE_ROOT=.
# HW_PROBE_TARGET_SPEC_PATH=target/target_spec.json

# 日志：<workspace>/log/ 下 hw_probe.debug.log（DEBUG 轮转）与 llm_trace.jsonl（完整 LLM/工具链回调）
# HW_PROBE_CONSOLE_LOG_LEVEL=INFO
# HW_PROBE_FILE_LOG_LEVEL=DEBUG
# HW_PROBE_LOG_DIR_NAME=log

HW_PROBE_SHELL_TIMEOUT_SEC=120
HW_PROBE_REACT_MAX_STEPS=24
HW_PROBE_SUPERVISOR_MAX_LOOPS=12
